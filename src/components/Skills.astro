---
import { es } from "../i18n/es";
import { getTechMeta } from "../lib/tech";
---

<section id="skills" class="section">
  <div class="container">
    <div class="section-heading" data-reveal style="--reveal-delay: 0ms;">
      <span class="section-eyebrow" data-i18n="skills.eyebrow">{es.skills.eyebrow}</span>
      <h2 class="section-title" data-i18n="skills.title">{es.skills.title}</h2>
      <p class="section-intro" data-i18n="skills.intro">{es.skills.intro}</p>
    </div>

    <div class="skills-grid">
      {
        es.skills.categories.map((category, categoryIndex) => (
          <article class="skill-card glass-card" data-reveal style={`--reveal-delay: ${categoryIndex * 80}ms;`}>
            <div class="skill-card-header">
              <h3 data-i18n={`skills.categories.${categoryIndex}.title`}>{category.title}</h3>
            </div>

            <div class="skill-badges">
              {
                category.items.map((item, itemIndex) => {
                  const meta = getTechMeta(item.key);

                  return (
                    <span class="skill-badge" style={`--badge-accent: ${meta.accent};`}>
                      <span class="skill-badge-icon" set:html={meta.icon}></span>
                      <span data-i18n={`skills.categories.${categoryIndex}.items.${itemIndex}.label`}>{item.label}</span>
                    </span>
                  );
                })
              }
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
