---
import { es } from "../i18n/es";

const basePath = import.meta.env.BASE_URL;
const cvUrl = `${basePath}Hoja_de_vida_Gelver_Villadiego.pdf`;

const contactIcons: Record<string, string> = {
  email: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3.5" y="5.5" width="17" height="13" rx="2.4" stroke="currentColor" stroke-width="1.6"/><path d="m5.5 8 6.5 5 6.5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  whatsapp: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 4.1A7.9 7.9 0 0 0 5.1 16L4 20l4.1-1A7.9 7.9 0 1 0 12 4.1Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M9.2 9.3c.3-.7.6-.7.9-.7h.6c.2 0 .4 0 .5.4l.5 1.5c.1.3 0 .5-.2.7l-.5.5c.5 1 1.2 1.7 2.2 2.2l.5-.5c.2-.2.4-.2.7-.1l1.4.6c.4.1.4.3.4.5v.6c0 .3-.1.6-.7.9-.5.2-1.5.3-3.4-.6-1.8-.9-3.1-2.8-3.4-3.4-.9-1.9-.8-2.9-.5-3.4Z" fill="currentColor"/></svg>`,
  github: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 19c-3.2.9-3.2-1.9-4.5-2.3M13.5 20v-2.4c0-.7.1-1.2-.3-1.7 2.3-.3 4.8-1.1 4.8-5a3.9 3.9 0 0 0-1.1-2.8c.1-.4.5-1.4-.1-2.8 0 0-.9-.3-3 1.1a10.2 10.2 0 0 0-5.4 0c-2.1-1.4-3-1.1-3-1.1-.6 1.4-.2 2.4-.1 2.8A3.9 3.9 0 0 0 4.2 11c0 3.8 2.4 4.7 4.8 5-.4.4-.4 1-.4 1.7V20" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  linkedin: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 9.5v7M7 6.8a.9.9 0 1 1 0 1.8.9.9 0 0 1 0-1.8ZM11.5 16.5v-4a2.1 2.1 0 0 1 4.2 0v4M15.7 9.5a4.1 4.1 0 0 1 4.1 4.1v2.9M11.5 9.5v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  location: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20.2s6-5.3 6-10.3a6 6 0 1 0-12 0c0 5 6 10.3 6 10.3Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><circle cx="12" cy="9.8" r="2.1" stroke="currentColor" stroke-width="1.6"/></svg>`
};
---

<section id="contact" class="section section-alt">
  <div class="container">
    <div class="section-heading" data-reveal style="--reveal-delay: 0ms;">
      <span class="section-eyebrow" data-i18n="contact.eyebrow">{es.contact.eyebrow}</span>
      <h2 class="section-title gradient-text" data-i18n="contact.title">{es.contact.title}</h2>
      <p class="section-intro" data-i18n="contact.intro">{es.contact.intro}</p>
    </div>

    <div class="contact-layout">
      <div class="contact-grid">
        {
          es.contact.items.map((item, index) =>
            item.href ? (
              <a
                class={`contact-card glass-card ${item.href === "#" ? "is-disabled" : ""}`}
                href={item.href}
                data-contact-kind={item.kind}
                target={item.href.startsWith("http") ? "_blank" : undefined}
                rel={item.href.startsWith("http") ? "noreferrer" : undefined}
                data-placeholder-link={item.href === "#" ? "true" : undefined}
                data-reveal
                style={`--reveal-delay: ${index * 70}ms;`}
              >
                <span class="contact-icon" set:html={contactIcons[item.kind]}></span>
                <div class="contact-copy">
                  <p class="contact-label" data-i18n={`contact.items.${index}.label`}>{item.label}</p>
                  <p class="contact-value" data-i18n={`contact.items.${index}.value`}>{item.value}</p>
                </div>
              </a>
            ) : (
              <article
                class="contact-card glass-card"
                data-contact-kind={item.kind}
                data-reveal
                style={`--reveal-delay: ${index * 70}ms;`}
              >
                <span class="contact-icon" set:html={contactIcons[item.kind]}></span>
                <div class="contact-copy">
                  <p class="contact-label" data-i18n={`contact.items.${index}.label`}>{item.label}</p>
                  <p class="contact-value" data-i18n={`contact.items.${index}.value`}>{item.value}</p>
                </div>
              </article>
            )
          )
        }
      </div>

      <aside class="contact-panel glass-card" data-reveal style="--reveal-delay: 180ms;">
        <div class="contact-panel-copy">
          <span class="availability-pill" data-i18n="contact.availability">{es.contact.availability}</span>
          <p data-i18n="contact.panelSummary">{es.contact.panelSummary}</p>
        </div>

        <a class="button button-primary contact-panel-action" href={cvUrl} download data-i18n="contact.cvCta">
          {es.contact.cvCta}
        </a>
      </aside>
    </div>
  </div>
</section>
